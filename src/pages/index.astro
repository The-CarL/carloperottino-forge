---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getPublishedProjects } from '../lib/projects';

const projects = await getPublishedProjects();
---

<Layout fullPage>
    <!-- Compact hero -->
    <section class="aurora-bg relative overflow-hidden px-6 pt-16 pb-12 sm:pt-20 sm:pb-16">
      <div class="flex flex-col items-center text-center max-w-md mx-auto">
        <!-- Anvil hero mark -->
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          class="w-20 sm:w-24 h-auto mb-6 text-cream ember-glow hero-enter hero-enter-1"
          aria-hidden="true"
        >
          <!-- Anvil icon by Pictogrammers (Material Design Icons) — Pictogrammers Free License -->
          <path
            fill="currentColor"
            d="M9,5V10C13.03,12.47 8.44,14.97 6,16V19H21V16C14.59,13.27 17.47,9 22,8V5H9M2,6C2.81,8.13 4.42,9.5 9,10V6H2Z"
          ></path>
        </svg>

        <h1
          class="text-5xl sm:text-6xl font-bold tracking-[-0.035em] leading-none mb-4 hero-enter hero-enter-2"
        >
          <span class="gradient-text">Forge</span>
        </h1>

        <p
          class="font-mono text-[11px] uppercase tracking-[0.3em] text-warm-gray mb-6 hero-enter hero-enter-3"
        >
          by Carlo Perottino
        </p>

        <div
          class="w-20 h-[2px] mb-6 accent-gradient hero-enter hero-enter-4"
          aria-hidden="true"
        >
        </div>

        <p
          class="font-normal text-sm sm:text-base text-warm-gray leading-relaxed max-w-sm hero-enter hero-enter-5"
        >
          Things I need. Things I want. Things that interest me.
        </p>
      </div>
    </section>

    <!-- Catalog -->
    <section class="relative z-10 max-w-5xl mx-auto px-6 pb-20 pt-8">
      {projects.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {projects.map((project) => (
            <ProjectCard project={project} />
          ))}
        </div>
      ) : (
        <p class="text-warm-dim text-center py-12">No projects yet.</p>
      )}
    </section>

    <footer class="relative z-10 px-6 pb-10 flex justify-center">
      <a
        href="https://carloperottino.com"
        class="font-mono text-[11px] uppercase tracking-[0.25em] text-warm-dim hover:text-accent transition-colors duration-300 inline-flex items-center gap-2"
      >
        <span aria-hidden="true">&larr;</span>
        carloperottino.com
      </a>
    </footer>
</Layout>
