---
import "../styles/global.css";
import Analytics from '@vercel/analytics/astro';
import ThemeToggle from '../components/ThemeToggle.astro';

const title = "Forge — by Carlo Perottino";
const description =
  "A builder's forge. Project catalog and launchpad — coming soon.";
const url = "https://forge.carloperottino.com/";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <script is:inline>
      (function() {
        const theme = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (theme === 'dark' || (!theme && prefersDark)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a0a" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={url} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <Analytics />
  </head>
  <body
    class="relative min-h-screen flex flex-col font-sans text-cream antialiased overflow-x-hidden"
  >
    <div class="fixed top-5 right-5 z-50">
      <ThemeToggle />
    </div>

    <main
      class="aurora-bg relative overflow-hidden z-10 flex-1 flex items-center justify-center px-6 py-20"
    >
      <div class="flex flex-col items-center text-center max-w-md">
        <!-- Anvil hero mark -->
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 100 80"
          class="w-32 sm:w-36 h-auto mb-10 text-cream hero-enter hero-enter-1"
          aria-hidden="true"
        >
          <!-- Two ember sparks above the face (struck moment) -->
          <circle cx="48" cy="6" r="1.6" fill="var(--color-ember)" class="ember-glow ember-spark-1"></circle>
          <circle cx="58" cy="10" r="1.1" fill="var(--color-ember)" class="ember-glow ember-spark-2"></circle>

          <!-- Anvil body — single closed path, clockwise from horn tip -->
          <path
            d="M 4 28 L 22 20 L 78 20 L 84 24 L 84 30 L 78 34 L 60 34 L 52 46 L 70 56 L 84 56 L 84 64 L 16 64 L 16 56 L 30 56 L 48 46 L 40 34 L 22 34 L 16 30 L 16 24 Z"
            fill="currentColor"
          ></path>
        </svg>

        <h1
          class="text-7xl sm:text-8xl font-bold tracking-[-0.035em] leading-none mb-4 hero-enter hero-enter-2"
        >
          <span class="gradient-text">Forge</span>
        </h1>

        <p
          class="font-mono text-[11px] uppercase tracking-[0.3em] text-warm-gray mb-10 hero-enter hero-enter-3"
        >
          by Carlo Perottino
        </p>

        <div
          class="w-20 h-[2px] mb-10 accent-gradient hero-enter hero-enter-4"
          aria-hidden="true"
        >
        </div>

        <p
          class="text-base sm:text-lg leading-relaxed text-warm-gray mb-12 max-w-sm hero-enter hero-enter-5"
        >
          A workshop for building, refining, and shipping ideas. <br
            class="hidden sm:block"
          />
          Where things get made.
        </p>

        <p
          class="font-mono text-[11px] uppercase tracking-[0.3em] text-accent mb-16 inline-flex items-center gap-3 hero-enter hero-enter-6"
        >
          <span
            class="inline-block w-1.5 h-1.5 rounded-full bg-accent ember-dot"
          ></span>
          Coming Soon
        </p>
      </div>
    </main>

    <footer class="relative z-10 px-6 pb-10 flex justify-center">
      <a
        href="https://carloperottino.com"
        class="font-mono text-[11px] uppercase tracking-[0.25em] text-warm-dim hover:text-accent transition-colors duration-300 inline-flex items-center gap-2"
      >
        <span aria-hidden="true">←</span>
        carloperottino.com
      </a>
    </footer>
  </body>
</html>
