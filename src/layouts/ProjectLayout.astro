---
import Layout from './Layout.astro';
import ProjectNav from '../components/ProjectNav.astro';
import FormattedDate from '../components/FormattedDate.astro';
import FreshnessBadge from '../components/FreshnessBadge.astro';
import TagList from '../components/TagList.astro';
import TableOfContents from '../components/TableOfContents.astro';
import { getReadingTime } from '../lib/reading-time';
import type { Project } from '../lib/projects';
import type { MarkdownHeading } from 'astro';

interface Props {
  project: Project;
  headings: MarkdownHeading[];
}

const { project, headings } = Astro.props;
const { title, tagline, date, updatedDate, tags, heroImage, links, comingSoon } = project.data;
const readingTime = project.body ? getReadingTime(project.body) : '';
---

<Layout title={`${title} | Forge`} description={tagline} fullPage>
  <ProjectNav />
  <main class="max-w-3xl mx-auto px-6 py-12">
    <article>
      <header class="mb-10">
        <a
          href="/"
          class="inline-flex items-center gap-1.5 text-sm text-warm-dim hover:text-accent transition-colors mb-6"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
          </svg>
          Back to Forge
        </a>

        <h1 class="text-3xl sm:text-4xl font-bold tracking-tight text-cream">
          {title}
        </h1>

        <p class="mt-2 text-lg text-warm-gray">
          {tagline}
        </p>

        <div class="flex items-center gap-3 mt-4">
          <FreshnessBadge date={updatedDate ?? date} comingSoon={comingSoon} />
        </div>

        <div class="flex items-center gap-3 mt-3 text-sm text-warm-dim">
          <FormattedDate date={date} />
          {readingTime && (
            <>
              <span class="text-surface-3">&middot;</span>
              <span>{readingTime}</span>
            </>
          )}
        </div>

        {updatedDate && (
          <p class="mt-2 text-sm text-warm-dim italic">
            Updated <FormattedDate date={updatedDate} />
          </p>
        )}

        {tags.length > 0 && <TagList tags={tags} class="mt-4" />}

        {(links.github || links.live || links.blog) && (
          <div class="flex flex-wrap gap-3 mt-5">
            {links.github && (
              <a
                href={links.github}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 text-sm px-3 py-1.5 rounded-full border border-surface-3 text-warm-gray hover:text-accent hover:border-accent/30 transition-all duration-200"
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                </svg>
                GitHub
              </a>
            )}
            {links.live && (
              <a
                href={links.live}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 text-sm px-3 py-1.5 rounded-full border border-surface-3 text-warm-gray hover:text-accent hover:border-accent/30 transition-all duration-200"
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                </svg>
                Live
              </a>
            )}
            {links.blog && (
              <a
                href={links.blog}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 text-sm px-3 py-1.5 rounded-full border border-surface-3 text-warm-gray hover:text-accent hover:border-accent/30 transition-all duration-200"
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
                </svg>
                Blog Post
              </a>
            )}
          </div>
        )}
      </header>

      {heroImage && (
        <img
          src={heroImage}
          alt={title}
          class="w-full rounded-lg mb-10 border border-surface-3"
        />
      )}

      <TableOfContents headings={headings} />

      <div class="prose">
        <slot />
      </div>
    </article>

    <div class="mt-16 pt-8 border-t border-surface-3/50">
      <a
        href="/"
        class="inline-flex items-center gap-1.5 text-sm text-accent hover:text-accent-light transition-colors"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
        </svg>
        All projects
      </a>
    </div>
  </main>

  <footer class="border-t border-surface-3/50 mt-16">
    <div class="max-w-3xl mx-auto px-6 py-8 text-center text-sm text-warm-dim">
      &copy; {new Date().getFullYear()} Carlo Perottino
    </div>
  </footer>
</Layout>
